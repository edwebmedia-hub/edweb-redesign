# Server
PORT=3000

# Owner master key - full access to all sites
OWNER_MASTER_KEY=change-me-master-key

# Secret used to sign session JWTs
JWT_SECRET=change-me-jwt-secret

# Filesystem storage root (used when MONGODB_URI is not set)
DATA_DIR=./data

# Optional: switch storage to MongoDB by setting a connection string
# MONGODB_URI=mongodb://localhost:27017/client-cms

# Optional: AI chat providers (either or both)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Optional: Vercel publish target
# VERCEL_TOKEN=...
# VERCEL_TEAM_ID=...
